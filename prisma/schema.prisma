generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id                Int               @id @default(autoincrement())
  name              String
  branchName        String?
  owner             String?
  phone             String?
  location          String?
  status            String            @default("Active")
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  managerEmail      String?
  managerName       String?
  sdkApiKey         String?
  sdkApiSecret      String?
  Amenity           Amenity[]
  announcements     Announcement[]
  Attendance        Attendance[]
  classes           Class[]
  commissions       Commission[]
  coupons           Coupon[]
  equipment         Equipment[]
  expenses          Expense[]
  expenseCategories ExpenseCategory[]
  inventory         Inventory[]
  invoices          Invoice[]
  leads             Lead[]
  lockers           Locker[]
  members           Member[]
  plans             MembershipPlan[]
  payroll           Payroll[]
  ptAccounts        PTMemberAccount[]
  ptPackages        PTPackage[]
  ptSessions        PTSession[]
  serviceRequests   ServiceRequest[]
  storeCategories   StoreCategory[]
  storeOrders       StoreOrder[]
  storeProducts     StoreProduct[]
  subscriptions     Subscription[]
  tasks             Task[]
  users             User[]

  @@map("tenant")
}

model ExpenseCategory {
  id          Int      @id @default(autoincrement())
  tenantId    Int
  name        String
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId], map: "expensecat_tenantId_fkey")
  @@map("expense_category")
}

model User {
  id               Int            @id @default(autoincrement())
  email            String         @unique
  password         String
  name             String
  phone            String?
  role             Role
  status           String         @default("Active")
  avatar           String?
  tenantId         Int?
  joinedDate       DateTime       @default(now())
  lastLogin        DateTime?
  address          String?        @db.Text
  accountNumber    String?
  baseSalary       Decimal?       @db.Decimal(10, 2)
  config           String?        @db.LongText
  department       String?
  documents        String?        @db.LongText
  ifsc             String?
  employeeCode     String?
  mipsPersonId     String?
  mipsPersonSn     String?
  mipsSyncStatus   String?        @default("pending")
  mipsSyncedAt     DateTime?
  attendances      Attendance[]
  receivedMessages ChatMessage[]  @relation("ReceivedMessages")
  sentMessages     ChatMessage[]  @relation("SentMessages")
  classes          Class[]
  commissions      Commission[]   @relation("TrainerCommissions")
  assignedLeads    Lead[]         @relation("LeadAssignee")
  assignedMember   Member[]       @relation("TrainerToMember")
  notifications    Notification[] @relation("UserNotifications")
  payrolls         Payroll[]
  ptSessions       PTSession[]    @relation("TrainerSessions")
  assignedTasks    Task[]         @relation("AssignedTasks")
  createdTasks     Task[]         @relation("CreatedTasks")
  managedTasks     Task[]         @relation("ManagerTasks")
  performingTasks  Task[]         @relation("StaffTasks")
  tenant           Tenant?        @relation(fields: [tenantId], references: [id])

  @@index([tenantId], map: "user_tenantId_fkey")
  @@map("user")
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  title     String
  message   String   @db.Text
  type      String   @default("info")
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
  user      User     @relation("UserNotifications", fields: [userId], references: [id])

  @@index([userId], map: "notification_userId_fkey")
  @@map("notification")
}

model SaaSPlan {
  id            Int            @id @default(autoincrement())
  name          String
  price         Decimal        @db.Decimal(10, 2)
  period        String
  features      String?        @db.LongText
  status        String         @default("Active")
  benefits      String?        @db.LongText
  createdAt     DateTime       @default(now())
  description   String?        @db.Text
  limits        String?        @db.LongText
  opsLimits     String?        @db.LongText
  updatedAt     DateTime       @updatedAt
  subscriptions Subscription[]

  @@map("saasplan")
}

model Subscription {
  id            String   @id @default(uuid())
  tenantId      Int
  planId        Int
  subscriber    String
  startDate     DateTime
  endDate       DateTime
  status        String
  paymentStatus String
  plan          SaaSPlan @relation(fields: [planId], references: [id])
  tenant        Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId], map: "subscription_tenantId_fkey")
  @@index([planId], map: "subscription_planId_fkey")
  @@map("subscription")
}

model AuditLog {
  id             Int      @id @default(autoincrement())
  userId         Int
  action         String
  affectedEntity String?
  details        String?  @db.Text
  module         String
  ip             String?
  createdAt      DateTime @default(now())
  status         String   @default("Open")

  @@map("auditlog")
}

model WebhookLog {
  id         String   @id @default(uuid())
  event      String
  status     String
  method     String
  endpoint   String
  statusCode Int
  payload    String?  @db.LongText
  createdAt  DateTime @default(now())

  @@map("webhooklog")
}

model SaaSSettings {
  id                 Int     @id @default(autoincrement())
  siteName           String  @default("Gym CRM")
  currency           String  @default("INR")
  timezone           String  @default("IST")
  invoicePrefix      String  @default("INV-")
  invoiceStartNumber Int     @default(1001)
  gstPercent         Decimal @default(18.00) @db.Decimal(5, 2)
  bookingEnabled     Boolean @default(true)
  creditsPerBooking  Int     @default(1)
  maxBookingsPerDay  Int     @default(2)
  maxBookingsPerWeek Int     @default(10)
  cancellationWindow Int     @default(4)
  advanceBookingDays Int     @default(7)
  penaltyEnabled     Boolean @default(true)
  penaltyCredits     Int     @default(1)
  contactAddress     String? @db.Text
  contactPhone       String?
  supportEmail       String?
  supportNumber      String?

  @@map("saassettings")
}

model SaasPayment {
  id         String   @id @default(uuid())
  paymentId  String   @unique
  tenantId   Int
  tenantName String
  amount     Decimal  @db.Decimal(10, 2)
  method     String
  status     String   @default("Success")
  date       DateTime @default(now())

  @@map("saaspayment")
}

model Device {
  id           Int      @id @default(autoincrement())
  name         String
  type         String
  status       String   @default("connected")
  message      String?
  tenantId     Int?
  lastSeen     DateTime @default(now())
  entriesToday Int      @default(0)
  ipAddress    String?
  branchId     Int?
  companyId    Int?
  deviceToken  String?
  port         Int?     @default(80)
  protocol     String?  @default("HTTP")
  sdkType      String?
  createdAt    DateTime @default(now())
  deviceKey    String?  @unique
  sdkApiKey    String?
  sdkApiSecret String?

  @@map("device")
}

model MipsConnection {
  id           Int      @id @default(autoincrement())
  branchId     Int      @unique
  serverUrl    String
  username     String
  password     String
  tenantId     String   @default("1")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  sdkApiKey    String?
  sdkApiSecret String?

  @@map("mips_connections")
}

model Member {
  id              Int               @id @default(autoincrement())
  memberId        String            @unique
  userId          Int?              @unique
  tenantId        Int
  planId          Int?
  joinDate        DateTime          @default(now())
  expiryDate      DateTime?
  status          String            @default("Active")
  trainerId       Int?
  avatar          String?
  benefits        String?           @db.LongText
  email           String?
  emergencyName   String?
  emergencyPhone  String?
  fitnessGoal     String?
  gender          String?
  medicalHistory  String?           @db.Text
  name            String?
  phone           String?
  targetBodyFat   Decimal?          @db.Decimal(5, 2)
  targetWeight    Decimal?          @db.Decimal(5, 2)
  address         String?           @db.Text
  dob             String?
  idNumber        String?
  idType          String?
  referralCode    String?
  source          String?
  mipsPersonId    String?
  mipsPersonSn    String?
  mipsSyncStatus  String?           @default("pending")
  mipsSyncedAt    DateTime?
  amenityBookings AmenityBooking[]
  amenityUsages   AmenityUsage[]
  attendances     Attendance[]
  bookings        Booking[]
  commissions     Commission[]      @relation("MemberCommissions")
  invoices        Invoice[]
  lockers         Locker[]
  plan            MembershipPlan?   @relation(fields: [planId], references: [id])
  tenant          Tenant            @relation(fields: [tenantId], references: [id])
  trainer         User?             @relation("TrainerToMember", fields: [trainerId], references: [id])
  ptAccounts      PTMemberAccount[]
  ptSessions      PTSession[]
  serviceRequests ServiceRequest[]
  storeOrders     StoreOrder[]
  usedCoupons     UsedCoupon[]

  @@index([planId], map: "member_planId_fkey")
  @@index([tenantId], map: "member_tenantId_fkey")
  @@index([trainerId], map: "member_trainerId_fkey")
  @@index([name])
  @@index([phone])
  @@index([email])
  @@map("member")
}

model ServiceRequest {
  id        Int      @id @default(autoincrement())
  tenantId  Int      @default(1)
  memberId  Int
  type      String
  rawType   String?
  details   String?  @db.Text
  status    String   @default("Pending")
  date      DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  member    Member   @relation(fields: [memberId], references: [id])
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId], map: "service_request_tenantId_fkey")
  @@index([memberId], map: "service_request_memberId_fkey")
  @@map("service_request")
}

model MembershipPlan {
  id                 Int      @id @default(autoincrement())
  tenantId           Int
  name               String
  price              Decimal  @db.Decimal(10, 2)
  duration           Int
  status             String   @default("Active")
  benefits           String?  @db.LongText
  cancellationWindow Int      @default(4)
  createdAt          DateTime @default(now())
  creditsPerBooking  Int      @default(1)
  description        String?  @db.Text
  durationType       String   @default("Months")
  maxBookingsPerDay  Int      @default(1)
  maxBookingsPerWeek Int      @default(7)
  updatedAt          DateTime @updatedAt
  allowTransfer      Boolean  @default(false)
  includeLocker      Boolean  @default(false)
  showInPurchase     Boolean  @default(true)
  showOnDashboard    Boolean  @default(true)
  members            Member[]
  tenant             Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId], map: "membershipplan_tenantId_fkey")
  @@map("membershipplan")
}

model Lead {
  id               Int        @id @default(autoincrement())
  tenantId         Int
  name             String
  email            String?
  phone            String
  source           String?
  status           String     @default("New")
  createdAt        DateTime   @default(now())
  age              Int?
  assignedToId     Int?
  budget           String?
  gender           String?
  interests        String?    @db.LongText
  nextFollowUp     DateTime?
  notes            String?    @db.Text
  preferredContact String?    @default("WhatsApp")
  updatedAt        DateTime   @updatedAt
  lostReason       String?
  rewardStatus     String     @default("Pending")
  followUps        FollowUp[]
  assignedTo       User?      @relation("LeadAssignee", fields: [assignedToId], references: [id])
  tenant           Tenant     @relation(fields: [tenantId], references: [id])

  @@index([assignedToId], map: "lead_assignedToId_fkey")
  @@index([tenantId], map: "lead_tenantId_fkey")
  @@index([name])
  @@index([phone])
  @@index([email])
  @@map("lead")
}

model FollowUp {
  id        Int       @id @default(autoincrement())
  leadId    Int
  notes     String?
  status    String
  nextDate  DateTime?
  createdAt DateTime  @default(now())
  lead      Lead      @relation(fields: [leadId], references: [id])

  @@index([leadId], map: "followup_leadId_fkey")
  @@map("followup")
}

model Class {
  id              Int       @id @default(autoincrement())
  tenantId        Int
  name            String
  description     String?   @db.Text
  trainerId       Int?
  schedule        String    @db.LongText
  maxCapacity     Int
  duration        String?
  location        String?
  requiredBenefit String?
  status          String    @default("Scheduled")
  price           Decimal?  @db.Decimal(10, 2)
  type            String    @default("Workout")
  bookings        Booking[]
  tenant          Tenant    @relation(fields: [tenantId], references: [id])
  trainer         User?     @relation(fields: [trainerId], references: [id])

  @@index([tenantId], map: "class_tenantId_fkey")
  @@index([trainerId], map: "class_trainerId_fkey")
  @@map("class")
}

model Booking {
  id       Int       @id @default(autoincrement())
  memberId Int
  classId  Int
  date     DateTime
  status   String    @default("Upcoming")
  class    Class     @relation(fields: [classId], references: [id])
  member   Member    @relation(fields: [memberId], references: [id])
  invoices Invoice[]

  @@index([classId], map: "booking_classId_fkey")
  @@index([memberId], map: "booking_memberId_fkey")
  @@map("booking")
}

model Inventory {
  id           Int     @id @default(autoincrement())
  tenantId     Int?
  itemName     String
  category     String
  quantity     Int
  unit         String
  minThreshold Int     @default(5)
  status       String  @default("In Stock")
  tenant       Tenant? @relation(fields: [tenantId], references: [id])

  @@index([tenantId], map: "inventory_tenantId_fkey")
  @@map("inventory")
}

model Locker {
  id           Int      @id @default(autoincrement())
  tenantId     Int?
  number       String
  status       String   @default("Available")
  assignedToId Int?
  area         String?
  createdAt    DateTime @default(now())
  isChargeable Boolean  @default(false)
  isPaid       Boolean  @default(false)
  notes        String?  @db.Text
  price        Decimal  @default(0.00) @db.Decimal(10, 2)
  size         String   @default("Medium")
  updatedAt    DateTime @updatedAt
  assignedTo   Member?  @relation(fields: [assignedToId], references: [id])
  tenant       Tenant?  @relation(fields: [tenantId], references: [id])

  @@index([tenantId], map: "locker_tenantId_fkey")
  @@index([assignedToId], map: "locker_memberId_fkey")
  @@map("locker")
}

model Equipment {
  id             Int                  @id @default(autoincrement())
  tenantId       Int?
  name           String
  status         String               @default("Operational")
  lastService    DateTime?
  nextService    DateTime?
  brand          String?
  category       String?
  location       String?
  model          String?
  purchaseDate   DateTime?
  serialNumber   String?
  warrantyExpiry DateTime?
  purchasePrice  Decimal?             @db.Decimal(10, 2)
  tenant         Tenant?              @relation(fields: [tenantId], references: [id])
  maintenance    MaintenanceRequest[]

  @@index([tenantId], map: "equipment_tenantId_fkey")
  @@map("equipment")
}

model MaintenanceRequest {
  id          Int       @id @default(autoincrement())
  equipmentId Int
  issue       String
  priority    String
  status      String    @default("Pending")
  createdAt   DateTime  @default(now())
  completedAt DateTime?
  cost        Decimal?  @default(0.00) @db.Decimal(10, 2)
  description String?   @db.Text
  equipment   Equipment @relation(fields: [equipmentId], references: [id])

  @@index([equipmentId], map: "maintenancerequest_equipmentId_fkey")
  @@map("maintenancerequest")
}

model Invoice {
  id             Int           @id @default(autoincrement())
  tenantId       Int
  invoiceNumber  String        @unique
  memberId       Int?
  amount         Decimal       @db.Decimal(10, 2)
  status         String        @default("Unpaid")
  dueDate        DateTime
  paidDate       DateTime?
  paymentMode    String        @default("Cash")
  discount       Decimal       @default(0.00) @db.Decimal(10, 2)
  notes          String?       @db.Text
  subtotal       Decimal       @default(0.00) @db.Decimal(10, 2)
  taxAmount      Decimal       @default(0.00) @db.Decimal(10, 2)
  taxRate        Decimal       @default(0.00) @db.Decimal(10, 2)
  bookingId      Int?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @default(now()) @updatedAt
  balance        Decimal       @default(0.00) @db.Decimal(10, 2)
  balanceDueDate DateTime?
  paidAmount     Decimal       @default(0.00) @db.Decimal(10, 2)
  booking        Booking?      @relation(fields: [bookingId], references: [id])
  member         Member?       @relation(fields: [memberId], references: [id])
  tenant         Tenant        @relation(fields: [tenantId], references: [id])
  items          InvoiceItem[]

  @@index([tenantId], map: "invoice_tenantId_fkey")
  @@index([status])
  @@index([paidDate])
  @@index([bookingId], map: "invoice_bookingId_fkey")
  @@index([memberId], map: "invoice_memberId_fkey")
  @@map("invoice")
}

model InvoiceItem {
  id          Int      @id @default(autoincrement())
  invoiceId   Int
  description String
  quantity    Int
  rate        Decimal  @db.Decimal(10, 2)
  amount      Decimal  @db.Decimal(10, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
  invoice     Invoice  @relation(fields: [invoiceId], references: [id])

  @@index([invoiceId], map: "invoiceitem_invoiceId_fkey")
  @@map("invoice_item")
}

model Expense {
  id       Int      @id @default(autoincrement())
  tenantId Int
  title    String
  category String
  amount   Decimal  @db.Decimal(10, 2)
  date     DateTime
  status   String   @default("Paid")
  addedBy  String?
  notes    String?  @db.Text
  tenant   Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId], map: "expense_tenantId_fkey")
  @@map("expense")
}

model Payroll {
  id              Int     @id @default(autoincrement())
  tenantId        Int
  staffId         Int
  amount          Decimal @db.Decimal(10, 2)
  month           Int
  year            Int
  status          String  @default("Pending")
  attendanceDays  Int     @default(0)
  baseSalary      Decimal @default(0.00) @db.Decimal(10, 2)
  commission      Decimal @default(0.00) @db.Decimal(10, 2)
  leaveDays       Int     @default(0)
  leaveDeduction  Decimal @default(0.00) @db.Decimal(10, 2)
  rejectionReason String? @db.Text
  staff           User    @relation(fields: [staffId], references: [id])
  tenant          Tenant  @relation(fields: [tenantId], references: [id])

  @@index([tenantId], map: "payroll_tenantId_fkey")
  @@index([staffId], map: "payroll_staffId_fkey")
  @@map("payroll")
}

model Attendance {
  id             Int       @id @default(autoincrement())
  userId         Int?
  checkIn        DateTime?
  checkOut       DateTime?
  type           String
  date           DateTime  @default(now())
  status         String    @default("Present")
  tenantId       Int       @default(1)
  memberId       Int?
  checkInMethod  String?
  checkOutMethod String?
  member         Member?   @relation(fields: [memberId], references: [id])
  tenant         Tenant    @relation(fields: [tenantId], references: [id])
  user           User?     @relation(fields: [userId], references: [id])

  @@index([tenantId], map: "attendance_tenantId_fkey")
  @@index([userId], map: "attendance_userId_fkey")
  @@index([memberId], map: "attendance_memberId_fkey")
  @@map("attendance")
}

model LeaveRequest {
  id        Int      @id @default(autoincrement())
  tenantId  Int      @default(1)
  userId    Int
  type      String   @default("Vacation")
  startDate DateTime
  endDate   DateTime
  reason    String   @db.Text
  status    String   @default("Pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId], map: "leave_request_tenantId_fkey")
  @@index([userId], map: "leave_request_userId_fkey")
  @@map("leave_request")
}

model TrainerAvailability {
  id             Int      @id @default(autoincrement())
  tenantId       Int      @default(1)
  trainerId      Int      @unique
  weeklySchedule String   @db.LongText
  preferences    String   @db.LongText
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("trainer_availability")
}

model Task {
  id             Int       @id @default(autoincrement())
  title          String
  assignedToId   Int?
  creatorId      Int
  priority       String    @default("Medium")
  dueDate        DateTime
  status         String    @default("Pending")
  description    String?   @db.Text
  tenantId       Int?
  createdAt      DateTime  @default(now())
  delegationNote String?   @db.Text
  managerId      Int?
  staffDeadline  DateTime?
  staffId        Int?
  updatedAt      DateTime  @updatedAt
  assignedTo     User?     @relation("AssignedTasks", fields: [assignedToId], references: [id])
  creator        User      @relation("CreatedTasks", fields: [creatorId], references: [id])
  manager        User?     @relation("ManagerTasks", fields: [managerId], references: [id])
  staff          User?     @relation("StaffTasks", fields: [staffId], references: [id])
  tenant         Tenant?   @relation(fields: [tenantId], references: [id])

  @@index([assignedToId], map: "Task_assignedToId_fkey")
  @@index([creatorId], map: "Task_creatorId_fkey")
  @@index([managerId])
  @@index([staffId])
  @@index([tenantId], map: "task_tenantId_fkey")
  @@map("task")
}

model Wallet {
  id       Int     @id @default(autoincrement())
  memberId Int     @unique
  balance  Decimal @default(0.00) @db.Decimal(10, 2)

  @@map("wallet")
}

model Transaction {
  id          Int      @id @default(autoincrement())
  walletId    Int
  amount      Decimal  @db.Decimal(10, 2)
  type        String
  description String?
  createdAt   DateTime @default(now())

  @@index([walletId], map: "Transaction_walletId_fkey")
  @@map("transaction")
}

model MemberProgress {
  id           Int      @id @default(autoincrement())
  memberId     Int
  weight       Decimal? @db.Decimal(5, 2)
  bodyFat      Decimal? @db.Decimal(5, 2)
  notes        String?
  date         DateTime @default(now())
  measurements String?  @db.LongText
  photos       String?  @db.LongText

  @@index([memberId], map: "MemberProgress_memberId_fkey")
  @@map("memberprogress")
}

model Announcement {
  id         Int      @id @default(autoincrement())
  title      String
  content    String   @db.Text
  authorId   Int
  createdAt  DateTime @default(now())
  priority   Int      @default(0)
  targetRole String   @default("all")
  tenantId   Int      @default(1)
  status     String   @default("Active")
  updatedAt  DateTime @default(now()) @updatedAt
  tenant     Tenant   @relation(fields: [tenantId], references: [id])

  @@index([authorId], map: "Announcement_authorId_fkey")
  @@index([tenantId], map: "announcement_tenantId_fkey")
  @@map("announcement")
}

model MessageTemplate {
  id        Int      @id @default(autoincrement())
  tenantId  Int      @default(1)
  name      String
  content   String   @db.LongText
  channel   String
  category  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("message_template")
}

model CommunicationLog {
  id        Int      @id @default(autoincrement())
  tenantId  Int      @default(1)
  senderId  Int?
  memberId  Int?
  channel   String
  message   String   @db.LongText
  status    String   @default("Sent")
  createdAt DateTime @default(now())

  @@map("communication_log")
}

model TenantSettings {
  id                    Int     @id @default(autoincrement())
  tenantId              Int     @unique
  logo                  String?
  timezone              String  @default("UTC")
  currency              String  @default("USD")
  whatsappEnabled       Boolean @default(false)
  announcements         Boolean @default(true)
  classNotifications    Boolean @default(true)
  fiscalYearStart       String  @default("April")
  googleBusinessEnabled Boolean @default(false)
  googleReviewLink      String? @db.Text
  loginAlerts           Boolean @default(true)
  lowStockAlerts        Boolean @default(true)
  membershipReminders   Boolean @default(true)
  newLeadAlerts         Boolean @default(true)
  paymentAlerts         Boolean @default(true)
  paymentReceipts       Boolean @default(true)
  sessionDuration       String  @default("8")
  sessionTimeout        Boolean @default(true)
  taskReminders         Boolean @default(true)
  twoFactorAuth         Boolean @default(false)
  referralReward        Int     @default(500)
  email                 String?

  @@map("tenantsettings")
}

model Reward {
  id          Int      @id @default(autoincrement())
  tenantId    Int?
  memberId    Int?
  name        String   @default("Reward")
  points      Int      @default(0)
  description String   @default("")
  date        DateTime @default(now())

  @@map("reward")
}

model Feedback {
  id                  Int      @id @default(autoincrement())
  tenantId            Int?
  memberId            Int?
  rating              Int
  comment             String   @db.Text
  status              String   @default("Pending")
  date                DateTime @default(now())
  isPublishedToGoogle Boolean  @default(false)

  @@map("feedback")
}

model DietPlan {
  id        String    @id @default(uuid())
  tenantId  Int       @default(1)
  trainerId Int
  clientId  Int
  name      String
  target    String
  duration  String
  calories  Int
  macros    String    @db.LongText
  meals     String    @db.LongText
  notes     String?   @db.Text
  status    String    @default("Active")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  endDate   DateTime?
  startDate DateTime?

  @@map("diet_plan")
}

model WorkoutPlan {
  id             String    @id @default(uuid())
  tenantId       Int       @default(1)
  trainerId      Int
  clientId       Int
  name           String
  level          String    @default("Beginner")
  duration       String
  goal           String
  volume         String
  timePerSession String
  intensity      String
  status         String    @default("Active")
  days           String    @db.LongText
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  endDate        DateTime?
  startDate      DateTime?

  @@map("workout_plan")
}

model Coupon {
  id                Int          @id @default(autoincrement())
  tenantId          Int?
  code              String       @unique
  description       String?      @db.Text
  type              String       @default("Percentage")
  value             Decimal      @db.Decimal(10, 2)
  minPurchase       Decimal?     @default(0.00) @db.Decimal(10, 2)
  maxUses           Int?         @default(0)
  usedCount         Int          @default(0)
  startDate         DateTime     @default(now())
  endDate           DateTime?
  status            String       @default("Active")
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  applicableService String       @default("All")
  maximumDiscount   Decimal?     @db.Decimal(10, 2)
  targetedMemberIds String?      @db.Text
  visibilityType    String       @default("Public")
  tenant            Tenant?      @relation(fields: [tenantId], references: [id])
  usedBy            UsedCoupon[]

  @@index([tenantId], map: "coupon_tenantId_fkey")
  @@map("coupon")
}

model UsedCoupon {
  id       Int      @id @default(autoincrement())
  couponId Int
  memberId Int
  usedAt   DateTime @default(now())
  coupon   Coupon   @relation(fields: [couponId], references: [id])
  member   Member   @relation(fields: [memberId], references: [id])

  @@index([couponId], map: "usedcoupon_couponId_fkey")
  @@index([memberId], map: "usedcoupon_memberId_fkey")
  @@map("used_coupon")
}

model StoreCategory {
  id          Int            @id @default(autoincrement())
  tenantId    Int?
  name        String
  description String?        @db.Text
  image       String?
  sortOrder   Int            @default(0)
  status      String         @default("Active")
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  tenant      Tenant?        @relation(fields: [tenantId], references: [id])
  products    StoreProduct[]

  @@index([tenantId], map: "storecategory_tenantId_fkey")
  @@map("store_category")
}

model StoreProduct {
  id            Int              @id @default(autoincrement())
  tenantId      Int?
  categoryId    Int?
  name          String
  sku           String?          @unique
  category      String?
  price         Decimal          @db.Decimal(10, 2)
  originalPrice Decimal?         @db.Decimal(10, 2)
  costPrice     Decimal?         @db.Decimal(10, 2)
  taxRate       Decimal?         @default(0.00) @db.Decimal(5, 2)
  stock         Int              @default(0)
  status        String           @default("Active")
  description   String?          @db.Text
  image         String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  orderItems    StoreOrderItem[]
  categoryRel   StoreCategory?   @relation(fields: [categoryId], references: [id])
  tenant        Tenant?          @relation(fields: [tenantId], references: [id])

  @@index([tenantId], map: "storeproduct_tenantId_fkey")
  @@index([categoryId], map: "storeproduct_categoryId_fkey")
  @@map("store_product")
}

model StoreOrder {
  id              Int              @id @default(autoincrement())
  tenantId        Int?
  memberId        Int?
  total           Decimal          @db.Decimal(10, 2)
  itemsCount      Int              @default(0)
  status          String           @default("Processing")
  date            DateTime         @default(now())
  guestName       String?
  guestPhone      String?
  guestEmail      String?
  couponCode      String?
  discountAmount  Decimal?         @default(0.00) @db.Decimal(10, 2)
  paymentMode     String?          @default("Cash")
  referenceNumber String?
  member          Member?          @relation(fields: [memberId], references: [id])
  tenant          Tenant?          @relation(fields: [tenantId], references: [id])
  items           StoreOrderItem[]

  @@index([tenantId], map: "storeorder_tenantId_fkey")
  @@index([memberId], map: "storeorder_memberId_fkey")
  @@map("store_order")
}

model StoreOrderItem {
  id         Int          @id @default(autoincrement())
  orderId    Int
  productId  Int
  quantity   Int
  priceAtBuy Decimal      @db.Decimal(10, 2)
  order      StoreOrder   @relation(fields: [orderId], references: [id])
  product    StoreProduct @relation(fields: [productId], references: [id])

  @@index([orderId], map: "storeorderitem_orderId_fkey")
  @@index([productId], map: "storeorderitem_productId_fkey")
  @@map("store_order_item")
}

model Amenity {
  id          Int              @id @default(autoincrement())
  tenantId    Int
  name        String
  description String?          @db.Text
  icon        String?          @default("Layers")
  status      String           @default("Active")
  gender      String           @default("UNISEX")
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  extraPrice  Decimal          @default(0.00) @db.Decimal(10, 2)
  slotEnabled Boolean          @default(false)
  tenant      Tenant           @relation(fields: [tenantId], references: [id])
  bookings    AmenityBooking[]
  slots       AmenitySlot[]
  usages      AmenityUsage[]

  @@index([tenantId], map: "amenity_tenantId_fkey")
  @@map("amenity")
}

model AmenitySlot {
  id        Int              @id @default(autoincrement())
  amenityId Int
  startTime String
  endTime   String
  capacity  Int              @default(5)
  bookings  AmenityBooking[]
  amenity   Amenity          @relation(fields: [amenityId], references: [id], onDelete: Cascade)

  @@index([amenityId])
  @@map("amenity_slot")
}

model AmenityBooking {
  id            Int          @id @default(autoincrement())
  memberId      Int
  amenityId     Int
  slotId        Int?
  date          DateTime
  status        String       @default("Booked")
  paymentStatus String       @default("None")
  amount        Decimal      @default(0.00) @db.Decimal(10, 2)
  transactionId String?
  createdAt     DateTime     @default(now())
  amenity       Amenity      @relation(fields: [amenityId], references: [id])
  member        Member       @relation(fields: [memberId], references: [id])
  slot          AmenitySlot? @relation(fields: [slotId], references: [id])

  @@index([memberId])
  @@index([amenityId])
  @@index([slotId])
  @@map("amenity_booking")
}

model AmenityUsage {
  id        Int     @id @default(autoincrement())
  memberId  Int
  amenityId Int
  month     Int
  year      Int
  usedCount Int     @default(0)
  limit     Int     @default(0)
  amenity   Amenity @relation(fields: [amenityId], references: [id])
  member    Member  @relation(fields: [memberId], references: [id])

  @@unique([memberId, amenityId, month, year])
  @@index([amenityId], map: "amenity_usage_amenityId_fkey")
  @@map("amenity_usage")
}

model PTPackage {
  id            Int               @id @default(autoincrement())
  tenantId      Int
  name          String
  sessionType   String            @default("Fixed Sessions")
  totalSessions Int
  price         Decimal           @db.Decimal(10, 2)
  gstPercent    Decimal           @default(18.00) @db.Decimal(5, 2)
  gstInclusive  Boolean           @default(false)
  validityDays  Int               @default(90)
  description   String?           @db.Text
  status        String            @default("Active")
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  accounts      PTMemberAccount[]
  tenant        Tenant            @relation(fields: [tenantId], references: [id])

  @@index([tenantId], map: "pt_package_tenantId_fkey")
  @@map("pt_package")
}

model PTMemberAccount {
  id                Int         @id @default(autoincrement())
  tenantId          Int
  memberId          Int
  packageId         Int
  totalSessions     Int
  remainingSessions Int
  expiryDate        DateTime
  status            String      @default("Active")
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  member            Member      @relation(fields: [memberId], references: [id])
  package           PTPackage   @relation(fields: [packageId], references: [id])
  tenant            Tenant      @relation(fields: [tenantId], references: [id])
  sessions          PTSession[]

  @@index([memberId], map: "pt_member_account_memberId_fkey")
  @@index([packageId], map: "pt_member_account_packageId_fkey")
  @@index([tenantId], map: "pt_member_account_tenantId_fkey")
  @@map("pt_member_account")
}

model PTSession {
  id          Int              @id @default(autoincrement())
  tenantId    Int
  memberId    Int
  trainerId   Int
  ptAccountId Int?
  date        DateTime
  time        String?
  duration    Int              @default(60)
  notes       String?          @db.Text
  status      String           @default("Completed")
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  member      Member           @relation(fields: [memberId], references: [id])
  ptAccount   PTMemberAccount? @relation(fields: [ptAccountId], references: [id])
  tenant      Tenant           @relation(fields: [tenantId], references: [id])
  trainer     User             @relation("TrainerSessions", fields: [trainerId], references: [id])

  @@index([memberId], map: "pt_session_memberId_fkey")
  @@index([trainerId], map: "pt_session_trainerId_fkey")
  @@index([ptAccountId], map: "pt_session_ptAccountId_fkey")
  @@index([tenantId], map: "pt_session_tenantId_fkey")
  @@map("pt_session")
}

model ChatMessage {
  id             Int      @id @default(autoincrement())
  tenantId       Int      @default(1)
  senderId       Int
  receiverId     Int
  message        String?  @db.LongText
  attachmentUrl  String?  @db.LongText
  attachmentType String?  @default("image")
  isRead         Boolean  @default(false)
  createdAt      DateTime @default(now())
  receiver       User     @relation("ReceivedMessages", fields: [receiverId], references: [id])
  sender         User     @relation("SentMessages", fields: [senderId], references: [id])

  @@index([senderId])
  @@index([receiverId])
  @@map("chat_message")
}

model Commission {
  id          Int      @id @default(autoincrement())
  tenantId    Int
  trainerId   Int
  memberId    Int?
  invoiceId   Int?
  ptAccountId Int?
  amount      Decimal  @db.Decimal(10, 2)
  month       Int
  year        Int
  status      String   @default("Pending")
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  member      Member?  @relation("MemberCommissions", fields: [memberId], references: [id])
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  trainer     User     @relation("TrainerCommissions", fields: [trainerId], references: [id])

  @@index([trainerId])
  @@index([tenantId])
  @@index([memberId], map: "commission_memberId_fkey")
  @@map("commission")
}

model AccessLog {
  id               Int      @id @default(autoincrement())
  personId         String
  personName       String?
  personType       String?  @default("VISITOR")
  deviceKey        String?
  deviceName       String?
  passType         String?
  scanTime         DateTime
  branchId         Int?
  attendanceResult String?
  status           String?  @default("ALLOWED")
  createdAt        DateTime @default(now())

  @@index([branchId])
  @@index([scanTime])
  @@index([deviceKey])
  @@map("access_log")
}

enum Role {
  SUPER_ADMIN
  BRANCH_ADMIN
  MANAGER
  STAFF
  TRAINER
  MEMBER
}
